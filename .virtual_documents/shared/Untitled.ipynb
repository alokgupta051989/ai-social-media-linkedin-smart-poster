from langchain_aws import ChatBedrock
import boto3
from langgraph.graph import StateGraph
from pydantic import BaseModel

llm = ChatBedrock(
    model_id="anthropic.claude-3-haiku-20240307-v1:0",
    region_name="us-east-1"
)

s3 = boto3.client("s3", region_name="us-east-1")


from pydantic import BaseModel

class AgentState(BaseModel):
    topic: str
    draft: str = ""
    approved: bool = False


def generate_content(state: AgentState):
    ai_response = llm.invoke(f"Write a professional LinkedIn post about {state.topic}")
    draft_text = ai_response.content if hasattr(ai_response, "content") else str(ai_response)
    return {"draft": draft_text}

def approve_content(state: AgentState):
    ai_review = llm.invoke(f"Check if this content is safe and professional:\n{state.draft}")
    review_text = ai_review.content if hasattr(ai_review, "content") else str(ai_review)
    return {"approved": True}

def save_draft(state: AgentState):
    s3.put_object(
        Bucket="social-media-ai-agent-drafts",
        Key=f"{state.topic}.txt",
        Body=state.draft
    )
    return {}

def post_mock(state: AgentState):
    print("=== DRY RUN POST ===")
    print(state.draft)
    return {}


workflow = StateGraph(AgentState)
workflow.add_node("generate", generate_content)
workflow.add_node("approve", approve_content)
workflow.add_node("save", save_draft)
workflow.add_node("post", post_mock)
workflow.set_entry_point("generate")
workflow.add_edge("generate", "approve")
workflow.add_edge("approve", "save")
workflow.add_edge("save", "post")
app = workflow.compile()

app.invoke({"topic": "AI Agents in Android Development"})



